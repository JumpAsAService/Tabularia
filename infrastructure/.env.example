# ─────────────────────────────────────────────────────────────────────────────
# Tabularia — environment configuration
# Copy to `.env` and adjust. NEVER commit the real `.env`.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

APP__ENV_NAME=development
APP__DEBUG=true

# ── Broker / cache index (Valkey) ────────────────────────────────────────────
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__DB=0

# ── Object storage (any S3-compatible endpoint: MinIO, AWS S3, R2, B2…) ─────
STORAGE__ENDPOINT=http://minio:9000
STORAGE__ACCESS_KEY=minioadmin
STORAGE__SECRET_KEY=minioadmin          # change in production
STORAGE__BUCKET=data-prep
STORAGE__REGION=us-east-1

# ── Workers ──────────────────────────────────────────────────────────────────
CELERY__WORKER_CONCURRENCY=2

# ── Incremental step cache ───────────────────────────────────────────────────
CACHE__TTL_SECONDS=86400               # evict entries unused for 1 day
CACHE__SWEEP_INTERVAL_SECONDS=3600      # eviction sweep every hour

# ── Monitoring (Grafana admin) ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin            # change in production

# ── Metadata database (Postgres) ─────────────────────────────────────────────
DB__USER=tabularia
DB__PASSWORD=tabularia                  # change in production
DB__NAME=tabularia
DB__HOST=postgres
DB__PORT=5432

# ── Auth (gateway) ───────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
# In production the gateway REFUSES to start with the dev defaults below.
JWT__SECRET=change-me-in-production
JWT__ACCESS_TTL_MINUTES=720

# Initial admin user, seeded at first startup (existing users are never touched)
AUTH__ADMIN_EMAIL=admin@tabularia.local
AUTH__ADMIN_PASSWORD=admin              # change in production
AUTH__ADMIN_NAME=Administrator

# ── Database-connection credentials encryption (gateway + engine) ───────────
# Shared Fernet key: the gateway encrypts DB-connection passwords at rest and
# sends them still encrypted to the engine, which decrypts them only inside the
# worker. Leave empty in development (a built-in dev key is used); REQUIRED in
# production. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECURITY__FERNET_KEY=

# ── Internal engine URL (data plane, proxied by the gateway) ─────────────────
ENGINE__BASE_URL=http://backend:8000
