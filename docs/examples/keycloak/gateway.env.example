# OIDC / SSO — Keycloak example (append to infrastructure/.env).
# Matches the `tabularia` realm in realm-tabularia.json. See
# docs/design/sso-group-mapping.md. ROTATE the client secret for anything real.
OIDC__ENABLED=true
OIDC__ISSUER=http://localhost:8080/realms/tabularia
OIDC__CLIENT_ID=tabularia-gateway
OIDC__CLIENT_SECRET=tabularia-dev-secret
OIDC__REDIRECT_URI=http://localhost:8000/auth/sso/callback
# the groups mapper is attached to the client, so no custom 'groups' scope is
# requested; the 'groups' claim is emitted on every token regardless of scope
OIDC__SCOPES=openid profile email
OIDC__GROUPS_CLAIM=groups
# empty = allow every IdP group; comma-separated = restrict to these names
OIDC__GROUP_ALLOWLIST=
# false = only map to groups that already exist in Tabularia (safer for RBAC)
OIDC__AUTO_CREATE_GROUPS=false
# true = IdP owns membership (removes Tabularia groups not in the claim)
OIDC__AUTHORITATIVE=true
# membership of this IdP group grants is_superuser
OIDC__SUPERUSER_GROUP=tabularia-admins
